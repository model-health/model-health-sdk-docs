a = await service.data(","    ofType: [.kinematic, .visualization],","    for: activity",")","print(\"Downloaded \\(allData.count) result files\")"],"syntax":"swift","type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This method performs concurrent downloads for optimal performance."},{"type":"text","text":" "},{"type":"text","text":"Individual download failures do not affect other requests and failed downloads"},{"type":"text","text":" "},{"type":"text","text":"are silently excluded from results."}]}],"style":"note","name":"Note","type":"aside"}],"kind":"content"}],"metadata":{"title":"data(ofType:for:)","roleHeading":"Instance Method","role":"symbol","modules":[{"name":"ModelHealth"}],"externalID":"s:11ModelHealth0aB7ServiceC4data6ofType3forSayAA10ResultDataVGShyAA0hiF0OG_AA8ActivityVtYaF","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"data","kind":"identifier"},{"text":"(","kind":"text"},{"text":"ofType","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Set","kind":"typeIdentifier","preciseIdentifier":"s:Sh"},{"text":"<","kind":"text"},{"text":"ResultDataType","kind":"typeIdentifier","preciseIdentifier":"s:11ModelHealth14ResultDataTypeO"},{"text":">, ","kind":"text"},{"text":"for","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Activity","kind":"typeIdentifier","preciseIdentifier":"s:11ModelHealth8ActivityV"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" -> [","kind":"text"},{"text":"ResultData","kind":"typeIdentifier","preciseIdentifier":"s:11ModelHealth10ResultDataV"},{"text":"]","kind":"text"}]},"abstract":[{"text":"Downloads result data files from a processed activity.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://ModelHealth/documentation/ModelHealth":{"url":"\/documentation\/modelhealth","type":"topic","abstract":[],"identifier":"doc:\/\/ModelHealth\/documentation\/Model