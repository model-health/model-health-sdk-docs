sis data rather than the"},{"type":"text","text":" "},{"type":"text","text":"structured metrics provided by "},{"isActive":true,"type":"reference","identifier":"doc:\/\/ModelHealth\/documentation\/ModelHealth\/ModelHealthService\/downloadAnalysisResult(forActivity:resultTag:)"},{"type":"text","text":"."}]},{"level":2,"type":"heading","anchor":"Example","text":"Example"},{"type":"codeListing","code":["\/\/ Download kinematic data only","let kinematicData = await service.data(ofType: [.kinematic], for: activity)","","for result in kinematicData {","    switch result.fileType {","    case .json:","        let decoder = JSONDecoder()","        if let jsonData = try? decoder.decode([String: Any].self, from: result.data) {","            print(\"Parsed kinematic JSON\")","        }","","    case .csv:","        if let csvString = String(data: result.data, encoding: .utf8) {","            print(\"CSV data:\\n\\(csvString)\")","        }","    }","}","","\/\/ Download all available data types","let allData = await service.data(","    ofType: [.kinematic, .visualization],","    for: activity",")","print(\"Downloaded \\(allData.count) result files\")"],"syntax":"swift"},{"content":[{"inlineContent":[{"type":"text","text":"This method performs concurrent downloads for optimal performance."},{"type":"text","text":" "},{"type":"text","text":"Individual download failures do not affect other requests and failed downloads"},{"type":"text","text":" "},{"type":"text","text":"are silently excluded from results."}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"}]}],"abstract":[{"type":"text","text":"Downloads result data files from a processed activity."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/modelhealth\/modelhealthservice\/data(oftype:for:)"]}],"references":{"doc://ModelHealth/documentation/ModelHealth/ModelHealthService/data(ofType:for:)":{"title":"data(ofType:for:)","identifier":"doc:\/\/ModelHealth\/documentation\/ModelH