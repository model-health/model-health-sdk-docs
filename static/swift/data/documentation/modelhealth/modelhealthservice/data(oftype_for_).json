xt":" "},{"type":"text","text":"in their native file formats (JSON, CSV)."}],"type":"paragraph"},{"inlineContent":[{"text":"This method is useful when you need access to raw analysis data rather than the","type":"text"},{"text":" ","type":"text"},{"text":"structured metrics provided by ","type":"text"},{"identifier":"doc:\/\/ModelHealth\/documentation\/ModelHealth\/ModelHealthService\/downloadAnalysisResult(forActivity:resultTag:)","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Example","text":"Example","type":"heading","level":2},{"code":["\/\/ Download kinematic data only","let kinematicData = await service.data(ofType: [.kinematic], for: activity)","","for result in kinematicData {","    switch result.fileType {","    case .json:","        let decoder = JSONDecoder()","        if let jsonData = try? decoder.decode([String: Any].self, from: result.data) {","            print(\"Parsed kinematic JSON\")","        }","","    case .csv:","        if let csvString = String(data: result.data, encoding: .utf8) {","            print(\"CSV data:\\n\\(csvString)\")","        }","    }","}","","\/\/ Download all available data types","let allData = await service.data(","    ofType: [.kinematic, .visualization],","    for: activity",")","print(\"Downloaded \\(allData.count) result files\")"],"type":"codeListing","syntax":"swift"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"text":"This method performs concurrent downloads for optimal performance.","type":"text"},{"text":" ","type":"text"},{"text":"Individual download failures do not affect other requests and failed downloads","type":"text"},{"text":" ","type":"text"},{"text":"are silently excluded from results.","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"references":{"doc://ModelHealth/documentation/ModelHealth/ResultData":{"title":"ResultData","identifier":"doc:\/\/ModelHealth\/documentation\/ModelHealth\/ResultData","type":"topic"